<%#
  Accordion Item Component
  Individual accordion item - usually rendered by the parent accordion partial.

  Required locals:
    - title: String - The item title/question
    - content: String - The expandable content
    - unique_id: String - Unique identifier for ARIA attributes

  Optional locals:
    - default_open: Boolean (default: false) - Start expanded
    - disabled: Boolean (default: false) - Disable interaction
    - icon: String (default: "chevron") - Icon type: "chevron", "plus_minus", "left_arrow"
    - variant: String (default: "default") - Style: "default", "bordered", "floating"
    - item_classes: String (default: nil) - Additional CSS classes
%>

<% default_open ||= false %>
<% disabled ||= false %>
<% icon ||= "chevron" %>
<% variant ||= "default" %>
<% item_classes ||= nil %>
<% unique_id ||= SecureRandom.hex(4) %>

<%
  # State
  state = default_open ? "open" : "closed"
  aria_expanded = default_open ? "true" : "false"
  is_bordered = variant.to_s == "bordered"
  icon_left ||= false

  # Item container classes based on variant
  base_item_classes = case variant.to_s
    when "bordered"
      "overflow-hidden bg-neutral-100/60 dark:bg-neutral-800 border border-black/10 dark:border-white/10 items-center justify-between font-semibold transition-all hover:bg-neutral-100 dark:hover:bg-neutral-700/50 rounded-lg"
    when "floating"
      "mb-2"
    else
      "border-b pb-2 border-neutral-200 dark:border-neutral-700"
    end
  computed_item_classes = [base_item_classes, item_classes].compact.join(" ")

  # H3 classes based on variant
  h3_classes = is_bordered ? "flex text-base font-semibold mt-0 mb-0" : "flex text-base font-semibold mt-2 mb-0"

  # Icon rotation class based on icon type
  icon_rotation = case icon.to_s
    when "plus_minus"
      ""
    when "left_arrow"
      "[&[data-state=open]>svg]:rotate-0 [&[data-state=closed]>svg]:-rotate-90"
    else
      "[&[data-state=open]>svg]:rotate-180"
    end

  # Trigger button classes based on variant
  trigger_classes = if is_bordered
    "w-full rounded-lg flex flex-1 p-3 items-center justify-between font-medium transition-all #{icon_rotation} focus:outline-neutral-700 dark:focus:outline-white focus:-outline-offset-1"
  else
    "w-full flex flex-1 items-center text-left justify-between py-2 font-medium transition-all focus:outline-neutral-700 dark:focus:outline-white focus:outline-offset-2 px-2 hover:underline #{icon_rotation}"
  end

  # Disabled trigger classes
  disabled_trigger_classes = if is_bordered
    "w-full rounded-lg flex flex-1 p-3 items-center justify-between font-medium opacity-50 cursor-not-allowed"
  else
    "flex flex-1 items-center text-left justify-between py-2 font-medium px-2 opacity-50 cursor-not-allowed"
  end

  # Content classes - CSS Grid approach for smooth animation that handles nested content
  content_classes = "grid transition-[grid-template-rows] duration-300 ease-in-out data-[state=open]:grid-rows-[1fr] data-[state=closed]:grid-rows-[0fr]"

  # Inner wrapper classes for proper clipping
  content_inner_classes = "overflow-hidden min-h-0"

  # Content body classes for opacity transition
  content_body_classes = "opacity-0 transition-opacity duration-300 data-[state=open]:opacity-100"

  # Content padding classes
  content_padding_classes = is_bordered ? "px-4 py-3 bg-white dark:bg-neutral-700/50 text-sm font-normal" : "my-2 px-2 text-sm"

  # Icon color class
  icon_color = ""
%>

<%# Icon rendering helper - inlined to match ViewComponent structure %>
<% render_icon = lambda do |static:| %>
  <% data_target = static ? nil : "data-accordion-target=\"icon\"".html_safe %>
  <% case icon.to_s
     when "chevron" %>
    <%
      chevron_classes = "size-4 shrink-0 transition-transform duration-300#{icon_color}"
      chevron_classes += " rotate-180" if !static && default_open
    %>
    <svg xmlns="http://www.w3.org/2000/svg" class="<%= chevron_classes %>" width="18" height="18" viewBox="0 0 18 18" <%= data_target %>>
      <g fill="currentColor">
        <path d="M8.99999 13.5C8.80799 13.5 8.61599 13.4271 8.46999 13.2801L2.21999 7.03005C1.92699 6.73705 1.92699 6.26202 2.21999 5.96902C2.51299 5.67602 2.98799 5.67602 3.28099 5.96902L9.00099 11.689L14.721 5.96902C15.014 5.67602 15.489 5.67602 15.782 5.96902C16.075 6.26202 16.075 6.73705 15.782 7.03005L9.53199 13.2801C9.38599 13.4261 9.19399 13.5 9.00199 13.5H8.99999Z"></path>
      </g>
    </svg>
  <% when "plus_minus" %>
    <% plus_minus_classes = "size-4#{icon_color}" %>
    <svg xmlns="http://www.w3.org/2000/svg" class="<%= plus_minus_classes %>" width="18" height="18" viewBox="0 0 18 18" <%= data_target %>>
      <g fill="currentColor">
        <path d="M14.75,9.75H3.25c-.414,0-.75-.336-.75-.75s.336-.75,.75-.75H14.75c.414,0,.75,.336,.75,.75s-.336,.75-.75,.75Z"></path>
        <path d="M9,15.5c-.414,0-.75-.336-.75-.75V3.25c0-.414,.336-.75,.75-.75s.75,.336,.75,.75V14.75c0,.414-.336,.75-.75,.75Z" class="origin-center transition-all duration-300 scale-100 [button[aria-expanded=true]_&]:scale-0"></path>
      </g>
    </svg>
  <% when "left_arrow" %>
    <%
      rotation = default_open && !static ? "rotate-0" : "-rotate-90"
      left_arrow_classes = "size-4 shrink-0 transition-transform duration-300 #{rotation}#{icon_color}"
    %>
    <svg xmlns="http://www.w3.org/2000/svg" class="<%= left_arrow_classes %>" width="18" height="18" viewBox="0 0 18 18" <%= data_target %>>
      <g fill="currentColor">
        <path d="M8.99999 13.5C8.80799 13.5 8.61599 13.4271 8.46999 13.2801L2.21999 7.03005C1.92699 6.73705 1.92699 6.26202 2.21999 5.96902C2.51299 5.67602 2.98799 5.67602 3.28099 5.96902L9.00099 11.689L14.721 5.96902C15.014 5.67602 15.489 5.67602 15.782 5.96902C16.075 6.26202 16.075 6.73705 15.782 7.03005L9.53199 13.2801C9.38599 13.4261 9.19399 13.5 9.00199 13.5H8.99999Z"></path>
      </g>
    </svg>
  <% end %>
<% end %>

<div <%= "data-accordion-target=\"item\"".html_safe unless disabled %> data-state="<%= state %>" class="<%= computed_item_classes %>">
  <h3 data-state="<%= state %>" class="<%= h3_classes %>">
    <% if disabled %>
      <div class="<%= disabled_trigger_classes %>">
        <% if icon_left %>
          <%= capture { render_icon.call(static: true) } %>
          <span class="flex-1 font-medium text-neutral-600 dark:text-neutral-300"><%= title %></span>
        <% else %>
          <span class="text-neutral-600 dark:text-neutral-300"><%= title %></span>
          <%= capture { render_icon.call(static: true) } %>
        <% end %>
      </div>
    <% else %>
      <button
        type="button"
        data-accordion-target="trigger"
        data-action="click->accordion#toggle"
        aria-controls="<%= unique_id %>-content"
        aria-expanded="<%= aria_expanded %>"
        data-state="<%= state %>"
        id="<%= unique_id %>-trigger"
        class="<%= trigger_classes %>"
      >
        <% if icon_left %>
          <%= capture { render_icon.call(static: false) } %>
          <span class="flex-1 font-medium"><%= title %></span>
        <% else %>
          <%= title %>
          <%= capture { render_icon.call(static: false) } %>
        <% end %>
      </button>
    <% end %>
  </h3>

  <% unless disabled %>
    <div
      data-accordion-target="content"
      data-state="<%= state %>"
      id="<%= unique_id %>-content"
      role="region"
      aria-labelledby="<%= unique_id %>-trigger"
      class="<%= content_classes %>"
      <%= "hidden".html_safe unless default_open %>
    >
      <div class="<%= content_inner_classes %>">
        <div class="<%= content_padding_classes %> <%= content_body_classes %>" data-state="<%= state %>">
          <%= content.respond_to?(:html_safe) ? content.html_safe : content %>
        </div>
      </div>
    </div>
  <% end %>
</div>
