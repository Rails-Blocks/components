<%#
  Testimonial Component
  Display customer testimonials and reviews with customizable layouts.

  Required locals:
    - quote: String - The testimonial quote text
    - author_name: String - The author's name

  Optional locals:
    - author_title: String (default: nil) - The author's job title or role
    - author_image: String (default: nil) - URL to the author's avatar image
    - company: String (default: nil) - The author's company name
    - rating: Integer (default: nil) - Star rating (1-5), nil to hide
    - variant: String (default: "default") - Display variant: "default", "card", "centered"
    - size: String (default: "md") - Size variant: "sm", "md", "lg"
    - show_quote_icon: Boolean (default: false) - Whether to show the quote icon
    - classes: String (default: nil) - Additional CSS classes for the wrapper
%>

<% quote ||= "" %>
<% author_name ||= "" %>
<% author_title ||= nil %>
<% author_image ||= nil %>
<% company ||= nil %>
<% rating ||= nil %>
<% variant ||= "default" %>
<% size ||= "md" %>
<% show_quote_icon ||= false %>
<% classes ||= nil %>

<%
  # Normalize rating
  rating_value = rating.present? ? rating.to_i.clamp(0, 5) : nil
  show_rating = rating_value.present? && rating_value.positive?
  filled_stars = rating_value || 0
  empty_stars = 5 - filled_stars

  # Build author subtitle
  author_parts = []
  author_parts << author_title if author_title.present?
  author_parts << company if company.present?
  author_subtitle = author_parts.any? ? author_parts.join(" at ") : nil

  # Variant checks
  is_centered = variant.to_s == "centered"
  is_card = variant.to_s == "card"

  # Build variant classes
  variant_classes = case variant.to_s
    when "card"
      "bg-white dark:bg-neutral-900 rounded-lg border border-black/10 dark:border-white/10 p-6 sm:p-8"
    when "centered"
      "text-center"
    else
      ""
    end

  # Size-based classes
  quote_size_classes = case size.to_s
    when "sm" then "text-sm"
    when "lg" then "text-lg md:text-xl"
    else "text-base"
    end

  author_name_size_classes = case size.to_s
    when "sm" then "text-sm"
    when "lg" then "text-lg"
    else "text-base"
    end

  author_title_size_classes = case size.to_s
    when "sm" then "text-xs"
    when "lg" then "text-base"
    else "text-sm"
    end

  avatar_size_classes = case size.to_s
    when "sm" then "size-8"
    when "lg" then "size-14"
    else "size-10"
    end

  # Build final class strings
  wrapper_classes = [variant_classes, classes].compact.reject(&:empty?).join(" ")
  quote_classes = ["text-neutral-700 dark:text-neutral-300 leading-relaxed", quote_size_classes].join(" ")
  author_name_classes = ["font-semibold text-neutral-900 dark:text-white", author_name_size_classes].join(" ")
  author_title_classes = ["text-neutral-500 dark:text-neutral-400", author_title_size_classes].join(" ")
  avatar_classes = ["rounded-full object-cover", avatar_size_classes].join(" ")
  avatar_wrapper_classes = ["rounded-full bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center overflow-hidden", avatar_size_classes].join(" ")
%>

<div class="<%= wrapper_classes %>">
  <% if show_quote_icon && is_centered %>
    <div class="mb-6">
      <svg class="w-10 h-10 mx-auto text-neutral-300 dark:text-neutral-600" viewBox="0 0 24 24" fill="currentColor">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h4v10h-10z"/>
      </svg>
    </div>
  <% end %>

  <% if show_rating && is_centered %>
    <div class="flex justify-center mb-4">
      <div class="flex items-center space-x-1">
        <% filled_stars.times do %>
          <svg class="size-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        <% end %>
        <% empty_stars.times do %>
          <svg class="size-5 text-neutral-300 dark:text-neutral-600 fill-current" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if is_card && !is_centered %>
    <% if author_image.present? %>
      <div class="flex items-center mb-4">
        <div class="<%= avatar_wrapper_classes %>">
          <img src="<%= author_image %>" alt="<%= author_name %>" class="<%= avatar_classes %>">
        </div>
        <div class="ml-4">
          <div class="<%= author_name_classes %>"><%= author_name %></div>
          <% if author_subtitle.present? %>
            <div class="<%= author_title_classes %>"><%= author_subtitle %></div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if show_rating %>
      <div class="flex items-center mb-3">
        <% filled_stars.times do %>
          <svg class="size-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        <% end %>
        <% empty_stars.times do %>
          <svg class="size-5 text-neutral-300 dark:text-neutral-600 fill-current" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        <% end %>
      </div>
    <% end %>

    <blockquote class="<%= quote_classes %>">
      "<%= quote %>"
    </blockquote>

    <% if author_image.blank? %>
      <footer class="mt-4">
        <div class="<%= author_name_classes %>"><%= author_name %></div>
        <% if author_subtitle.present? %>
          <div class="<%= author_title_classes %>"><%= author_subtitle %></div>
        <% end %>
      </footer>
    <% end %>

  <% elsif is_centered %>
    <blockquote class="<%= quote_classes %> mb-6">
      "<%= quote %>"
    </blockquote>

    <footer class="flex flex-col items-center gap-3">
      <% if author_image.present? %>
        <div class="<%= avatar_wrapper_classes %>">
          <img src="<%= author_image %>" alt="<%= author_name %>" class="<%= avatar_classes %>">
        </div>
      <% end %>
      <div>
        <div class="<%= author_name_classes %>"><%= author_name %></div>
        <% if author_subtitle.present? %>
          <div class="<%= author_title_classes %>"><%= author_subtitle %></div>
        <% end %>
      </div>
    </footer>

  <% else %>
    <%# Default variant %>
    <blockquote class="<%= quote_classes %> mb-4">
      "<%= quote %>"
    </blockquote>

    <footer class="flex items-center">
      <% if author_image.present? %>
        <div class="<%= avatar_wrapper_classes %>">
          <img src="<%= author_image %>" alt="<%= author_name %>" class="<%= avatar_classes %>">
        </div>
        <div class="ml-3">
          <div class="<%= author_name_classes %>"><%= author_name %></div>
          <% if author_subtitle.present? %>
            <div class="<%= author_title_classes %>"><%= author_subtitle %></div>
          <% end %>
        </div>
      <% else %>
        <div>
          <div class="<%= author_name_classes %>"><%= author_name %></div>
          <% if author_subtitle.present? %>
            <div class="<%= author_title_classes %>"><%= author_subtitle %></div>
          <% end %>
        </div>
      <% end %>
    </footer>
  <% end %>
</div>
