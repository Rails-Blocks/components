<%#
  Carousel Component
  Image/content slider powered by Embla Carousel with keyboard navigation.

  Required locals:
    - slides: Array - Array of slide hashes or pass a block with content

  Optional locals:
    - loop: Boolean (default: false) - Enable infinite looping
    - drag_free: Boolean (default: false) - Enable free dragging without snap points
    - dots: Boolean (default: true) - Show navigation dots
    - buttons: Boolean (default: true) - Show prev/next navigation buttons
    - axis: String (default: "x") - Carousel axis: "x" (horizontal) or "y" (vertical)
    - thumbnails: Boolean (default: false) - Enable thumbnail navigation mode
    - main_carousel_id: String (default: nil) - ID of main carousel for thumbnail sync
    - wheel_gestures: Boolean (default: false) - Enable mouse wheel navigation
    - slide_size: String (default: "half") - Slide width: "full", "three_quarters", "two_thirds", "half", "third", "quarter"
    - show_gradients: Boolean (default: true) - Show edge fade on desktop
    - height: String (default: nil) - Fixed height class for vertical carousels (e.g., "h-96")
    - classes: String (default: nil) - Additional CSS classes for the wrapper
    - id: String (default: nil) - HTML ID attribute (required for thumbnail carousel connections)

  Slide hash keys:
    - content: String/HTML - The slide content
    - classes: String - Additional CSS classes for this slide
%>

<% slides = local_assigns.fetch(:slides, []) || [] %>
<%
  loop_enabled = if local_assigns.key?(:loop_enabled)
    local_assigns[:loop_enabled]
  elsif local_assigns.key?(:loop)
    local_assigns[:loop]
  else
    false
  end
%>
<%
  drag_free = local_assigns.fetch(:drag_free, false)
  dots = local_assigns.fetch(:dots, true)
  buttons = local_assigns.fetch(:buttons, true)
  axis = local_assigns.fetch(:axis, "x")
  thumbnails = local_assigns.fetch(:thumbnails, false)
  main_carousel_id = local_assigns.fetch(:main_carousel_id, nil)
  wheel_gestures = local_assigns.fetch(:wheel_gestures, false)
  slide_size = local_assigns.fetch(:slide_size, "half")
  show_gradients = local_assigns.fetch(:show_gradients, true)
  height = local_assigns.fetch(:height, nil)
  classes = local_assigns.fetch(:classes, nil)
  id = local_assigns.fetch(:id, nil)
%>

<%
  # Slide size classes mapping
  slide_size_classes = {
    "full" => "basis-full",
    "three_quarters" => "basis-full sm:basis-3/4",
    "two_thirds" => "basis-full sm:basis-3/4 md:basis-2/3",
    "half" => "basis-full sm:basis-3/4 md:basis-2/3 lg:basis-1/2",
    "third" => "basis-full sm:basis-1/2 md:basis-1/3",
    "quarter" => "basis-full sm:basis-1/2 md:basis-1/3 lg:basis-1/4"
  }

  # Wrapper classes
  base_wrapper = "overflow-hidden w-full"
  max_width = if axis.to_s == "y"
    "max-w-xs sm:max-w-md md:max-w-lg mx-auto"
  else
    "max-w-xs sm:max-w-md md:max-w-2xl lg:max-w-4xl xl:max-w-6xl mx-auto"
  end
  wrapper_classes = [base_wrapper, max_width, classes].compact.reject(&:empty?).join(" ")

  # Build data attributes
  data_attrs = { controller: "carousel" }
  data_attrs[:carousel_loop_value] = loop_enabled if loop_enabled
  data_attrs[:carousel_drag_free_value] = drag_free if drag_free
  data_attrs[:carousel_dots_value] = dots
  data_attrs[:carousel_buttons_value] = buttons
  data_attrs[:carousel_axis_value] = axis if axis.to_s != "x"
  data_attrs[:carousel_thumbnails_value] = thumbnails if thumbnails
  data_attrs[:carousel_main_carousel_value] = main_carousel_id if main_carousel_id
  data_attrs[:carousel_wheel_gestures_value] = wheel_gestures if wheel_gestures

  # Viewport classes
  show_edge_fade = show_gradients
  viewport_base = "overflow-hidden outline-hidden mx-4 sm:mx-6 md:mx-8 cursor-grab active:cursor-grabbing"
  viewport_height = axis.to_s == "y" ? (height || "h-96") : ""
  viewport_edge_fade = if show_edge_fade
    if axis.to_s == "y"
      "md:[--carousel-fade-size-y:1.25rem] md:[mask-image:linear-gradient(to_bottom,transparent,black_var(--carousel-fade-size-y),black_calc(100%-var(--carousel-fade-size-y)),transparent)] md:[-webkit-mask-image:linear-gradient(to_bottom,transparent,black_var(--carousel-fade-size-y),black_calc(100%-var(--carousel-fade-size-y)),transparent)]"
    else
      "md:[--carousel-fade-size:1.25rem] md:[mask-image:linear-gradient(to_right,transparent,black_var(--carousel-fade-size),black_calc(100%-var(--carousel-fade-size)),transparent)] md:[-webkit-mask-image:linear-gradient(to_right,transparent,black_var(--carousel-fade-size),black_calc(100%-var(--carousel-fade-size)),transparent)]"
    end
  else
    ""
  end
  viewport_classes = [viewport_base, viewport_height, viewport_edge_fade].reject(&:empty?).join(" ")

  # Slides container classes
  slides_container_classes = axis.to_s == "y" ? "flex flex-col h-full" : "flex"

  # Helper flags
  is_vertical = axis.to_s == "y"
  show_dots = dots
  show_buttons = buttons

  section_attrs = { data: data_attrs }
  section_attrs[:id] = id if id
%>

<section class="<%= wrapper_classes %>" <%= tag.attributes(section_attrs) %>>
  <div class="<%= viewport_classes %>" data-carousel-target="viewport">
    <div class="<%= slides_container_classes %>">
      <% slides.each_with_index do |slide, index| %>
        <%= render "shared/components/carousel/carousel_slide",
          content: slide[:content],
          slide_classes: slide[:classes],
          slide_size: slide_size,
          axis: axis,
          unique_id: "carousel-#{object_id}-slide-#{index}"
        %>
      <% end %>
    </div>

  </div>

  <% if show_buttons || show_dots %>
    <div class="flex justify-between items-center mt-4 px-4 sm:px-6 md:px-8">
      <% if show_buttons %>
        <div class="grid grid-cols-2 gap-2 items-center z-10">
          <button
            class="flex items-center justify-center size-10 rounded-full bg-white p-2 text-sm font-semibold text-neutral-800 shadow-xs hover:bg-neutral-50 outline-hidden border border-neutral-200 dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:hover:bg-neutral-700/75 disabled:opacity-80 disabled:cursor-not-allowed"
            type="button"
            data-carousel-target="prevButton"
            aria-label="Previous"
          >
            <% if is_vertical %>
              <svg xmlns="http://www.w3.org/2000/svg" class="text-neutral-700 dark:text-neutral-300 size-4" width="18" height="18" viewBox="0 0 18 18"><g fill="currentColor"><path d="M9.52999 4.71999C9.23699 4.42699 8.76199 4.42699 8.46899 4.71999L2.21999 10.97C1.92699 11.263 1.92699 11.738 2.21999 12.031C2.51299 12.324 2.988 12.324 3.281 12.031L9.001 6.311L14.721 12.031C14.867 12.177 15.059 12.251 15.251 12.251C15.443 12.251 15.635 12.178 15.781 12.031C16.074 11.738 16.074 11.263 15.781 10.97L9.531 4.71999H9.52999Z"></path></g></svg>
            <% else %>
              <svg xmlns="http://www.w3.org/2000/svg" class="text-neutral-700 dark:text-neutral-300 size-4" width="18" height="18" viewBox="0 0 18 18"><g fill="currentColor"><path d="M11.5 16C11.308 16 11.116 15.9271 10.97 15.7801L4.71999 9.53005C4.42699 9.23705 4.42699 8.76202 4.71999 8.46902L10.97 2.21999C11.263 1.92699 11.738 1.92699 12.031 2.21999C12.324 2.51299 12.324 2.98803 12.031 3.28103L6.311 9.001L12.031 14.721C12.324 15.014 12.324 15.489 12.031 15.782C11.885 15.928 11.693 16.002 11.501 16.002L11.5 16Z"></path></g></svg>
            <% end %>
          </button>

          <button
            class="flex items-center justify-center size-10 rounded-full bg-white p-2 text-sm font-semibold text-neutral-800 shadow-xs hover:bg-neutral-50 outline-hidden border border-neutral-200 dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:hover:bg-neutral-700/75 disabled:opacity-80 disabled:cursor-not-allowed"
            type="button"
            data-carousel-target="nextButton"
            aria-label="Next"
          >
            <% if is_vertical %>
              <svg xmlns="http://www.w3.org/2000/svg" class="text-neutral-700 dark:text-neutral-300 size-4" width="18" height="18" viewBox="0 0 18 18"><g fill="currentColor"><path d="M8.99999 13.5C8.80799 13.5 8.61599 13.4271 8.46999 13.2801L2.21999 7.03005C1.92699 6.73705 1.92699 6.26202 2.21999 5.96902C2.51299 5.67602 2.98799 5.67602 3.28099 5.96902L9.00099 11.689L14.721 5.96902C15.014 5.67602 15.489 5.67602 15.782 5.96902C16.075 6.26202 16.075 6.73705 15.782 7.03005L9.53199 13.2801C9.38599 13.4261 9.19399 13.5 9.00199 13.5H8.99999Z"></path></g></svg>
            <% else %>
              <svg xmlns="http://www.w3.org/2000/svg" class="text-neutral-700 dark:text-neutral-300 size-4" width="18" height="18" viewBox="0 0 18 18"><g fill="currentColor"><path d="M13.28 8.46999L7.03 2.21999C6.737 1.92699 6.262 1.92699 5.969 2.21999C5.676 2.51299 5.676 2.98803 5.969 3.28103L11.689 9.001L5.969 14.721C5.676 15.014 5.676 15.489 5.969 15.782C6.115 15.928 6.307 16.002 6.499 16.002C6.691 16.002 6.883 15.929 7.029 15.782L13.279 9.53201C13.572 9.23901 13.572 8.76403 13.279 8.47103L13.28 8.46999Z"></path></g></svg>
            <% end %>
          </button>
        </div>
      <% else %>
        <div></div>
      <% end %>

      <% if show_dots %>
        <div class="z-10 flex flex-wrap justify-end items-center gap-1.5" data-carousel-target="dotsContainer"></div>
      <% end %>
    </div>
  <% end %>
</section>
