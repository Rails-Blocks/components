<%
# Emoji Picker Component - Shared Partial
#
# A flexible emoji picker component using the emoji-mart library with support for
# selection, auto-submit, and insert mode for text fields.
#
# @param id [String] Unique identifier for the emoji picker
# @param name [String] Name attribute for the hidden input field (default: "emoji")
# @param value [String] Pre-selected emoji value (optional)
# @param placeholder [String] Placeholder text for visible input (default: "Select an emoji...")
# @param auto_submit [Boolean] Whether to automatically submit the form when an emoji is selected (default: false)
# @param insert_mode [Boolean] Whether to insert emoji at cursor position instead of replacing entire value (default: false)
# @param target_selector [String] CSS selector for a specific input/textarea to insert emoji into (optional)
# @param show_input [Boolean] Show text input displaying selected emoji (default: false)
# @param button_size [Symbol/String] Size of the trigger button - :sm, :md, :lg (default: :md)
# @param button_style [Symbol/String] Style variant for the trigger button - :ghost, :outline, :solid (default: :ghost)
# @param picker_position [Symbol/String] Position of the picker dropdown - :left, :center, :right (default: :center)
# @param classes [String] Additional CSS classes for the wrapper (optional)
# @param button_classes [String] Additional CSS classes for the button (optional)
# @param input_classes [String] Additional CSS classes for the input (optional)

id ||= "emoji_picker_#{SecureRandom.hex(4)}"
name ||= "emoji"
value ||= nil
placeholder ||= "Select an emoji..."
auto_submit ||= false
insert_mode ||= false
target_selector ||= nil
show_input ||= false
button_size ||= :md
button_style ||= :ghost
picker_position ||= :center
classes ||= ""
button_classes ||= ""
input_classes ||= ""

# Convert string params to symbols for consistency
button_size = button_size.to_sym if button_size.respond_to?(:to_sym)
button_style = button_style.to_sym if button_style.respond_to?(:to_sym)
picker_position = picker_position.to_sym if picker_position.respond_to?(:to_sym)

# Button size classes
button_size_classes = case button_size
                      when :sm then "size-6 text-base"
                      when :lg then "size-10 text-2xl"
                      else "size-8 text-xl"
                      end

# Button style classes
button_style_classes = case button_style
                       when :outline
                         "border border-neutral-200 dark:border-neutral-700 text-neutral-700 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800"
                       when :solid
                         "bg-neutral-100 dark:bg-neutral-800 text-neutral-700 hover:bg-neutral-200 dark:text-neutral-300 dark:hover:bg-neutral-700"
                       else # :ghost
                         "text-neutral-700 hover:bg-neutral-100 hover:text-neutral-800 dark:text-neutral-300 dark:hover:bg-neutral-800 dark:hover:text-neutral-200"
                       end

# Picker position classes
picker_position_classes = case picker_position
                          when :left then "justify-start"
                          when :right then "justify-end"
                          else "justify-center"
                          end

# Icon size based on button size
icon_size = case button_size
            when :sm then "size-4"
            when :lg then "size-6"
            else "size-5"
            end

has_emoji = value.present? && !insert_mode
%>

<div class="relative <%= classes %>"
     data-controller="emoji-picker"
     <% if auto_submit %>data-emoji-picker-auto-submit-value="true"<% end %>
     <% if insert_mode %>data-emoji-picker-insert-mode-value="true"<% end %>
     <% if target_selector.present? %>data-emoji-picker-target-selector-value="<%= target_selector %>"<% end %>>

  <% if insert_mode && target_selector.blank? && defined?(content) && content.present? %>
    <%= content %>
  <% end %>

  <div class="flex items-center gap-2">
    <button
      type="button"
      class="outline-hidden shrink-0 flex items-center justify-center rounded-md focus:outline-hidden disabled:pointer-events-none disabled:opacity-50 <%= button_size_classes %> <%= button_style_classes %> <%= button_classes %>"
      data-action="click->emoji-picker#toggle"
      data-emoji-picker-target="button"
    >
      <% if has_emoji %>
        <span class="size-6 text-xl shrink-0 flex items-center justify-center"><%= value %></span>
      <% else %>
        <svg xmlns="http://www.w3.org/2000/svg" class="<%= icon_size %>" width="18" height="18" viewBox="0 0 18 18"><g fill="currentColor"><path d="M9,1C4.589,1,1,4.589,1,9s3.589,8,8,8,8-3.589,8-8S13.411,1,9,1Zm-4,7c0-.552,.448-1,1-1s1,.448,1,1-.448,1-1,1-1-.448-1-1Zm4,6c-1.531,0-2.859-1.14-3.089-2.651-.034-.221,.039-.444,.193-.598,.151-.15,.358-.217,.572-.185,1.526,.24,3.106,.24,4.638,.001h0c.217-.032,.428,.036,.583,.189,.153,.153,.225,.373,.192,.589-.229,1.513-1.557,2.654-3.089,2.654Zm3-5c-.552,0-1-.448-1-1s.448-1,1-1,1,.448,1,1-.448,1-1,1Z"></path></g></svg>
      <% end %>
    </button>

    <% if show_input %>
      <input
        type="text"
        id="<%= id %>"
        name="<%= name %>"
        value="<%= value %>"
        placeholder="<%= placeholder %>"
        class="form-control <%= input_classes %>"
        data-emoji-picker-target="input"
        autocomplete="off"
      >
    <% else %>
      <input
        type="text"
        name="<%= name %>"
        value="<%= value %>"
        class="hidden"
        data-emoji-picker-target="input"
      >
    <% end %>
  </div>

  <div data-emoji-picker-target="pickerContainer" class="hidden absolute z-50 mt-2 flex inset-x-0 <%= picker_position_classes %>"></div>
</div>
