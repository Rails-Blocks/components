<!-- Full width button -->
<%= render Buttons::Component.new(
  text: "Full Width Button",
  full_width: true
) %>

<%= render Buttons::Component.new(
  text: "Full Width Secondary",
  variant: :secondary,
  full_width: true
) %>

<!-- As link (anchor tag) -->
<%= render Buttons::Component.new(
  text: "Visit Page",
  href: "#visit-page"
) %>

<%= render Buttons::Component.new(
  text: "External Link",
  variant: :secondary,
  href: "https://example.com"
) %>

<!-- Submit button -->
<%= render Buttons::Component.new(
  text: "Submit Form",
  type: "submit"
) %>

<!-- With custom classes -->
<%= render Buttons::Component.new(
  text: "Custom Styled",
  classes: "shadow-lg"
) %>

<!-- With data attributes -->
<%= render Buttons::Component.new(
  text: "With Data Attrs",
  data: { turbo_method: "delete", confirm: "Are you sure?" }
) %>

