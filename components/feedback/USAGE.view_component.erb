<!-- Basic feedback widget (centered) -->
<%= render Feedback::Component.new %>

<!-- Custom button text -->
<%= render Feedback::Component.new(
  button_text: "Send Feedback",
  placeholder: "What's on your mind?",
  submit_text: "Submit"
) %>

<!-- Top-left anchor point -->
<%= render Feedback::Component.new(
  anchor_point: :top_left,
  button_text: "Give Feedback"
) %>

<!-- Top-right anchor point -->
<%= render Feedback::Component.new(
  anchor_point: :top_right
) %>

<!-- Bottom-left anchor point -->
<%= render Feedback::Component.new(
  anchor_point: :bottom_left
) %>

<!-- Bottom-right anchor point -->
<%= render Feedback::Component.new(
  anchor_point: :bottom_right
) %>

<!-- Top center anchor point -->
<%= render Feedback::Component.new(
  anchor_point: :top
) %>

<!-- Bottom center anchor point -->
<%= render Feedback::Component.new(
  anchor_point: :bottom
) %>

<!-- Left anchor point -->
<%= render Feedback::Component.new(
  anchor_point: :left
) %>

<!-- Right anchor point -->
<%= render Feedback::Component.new(
  anchor_point: :right
) %>

<!-- With form action (server-side submission) -->
<%= render Feedback::Component.new(
  button_text: "Report Issue",
  placeholder: "Describe the issue...",
  submit_text: "Submit Report",
  form_action: "/feedback",
  form_method: "post",
  name: "issue_report"
) %>

<!-- With custom classes -->
<%= render Feedback::Component.new(
  button_text: "Feedback",
  classes: "max-w-md mx-auto"
) %>
