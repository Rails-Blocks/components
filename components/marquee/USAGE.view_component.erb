        </g>
      </svg>
      <span class="text-sm font-medium text-neutral-800 dark:text-neutral-200">Ruby on Rails</span>
    </div>
  <% end %>
  <% marquee.with_item do %>
    <div class="flex items-center space-x-2">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20" class="h-5">
        <path fill="#23B2E7" fill-rule="evenodd" d="M10 5Q6 5 5 8.334q1.5-1.668 3.5-1.25c.76.158 1.305.618 1.906 1.127C11.386 9.041 12.522 10 15 10q4 0 5-3.333-1.5 1.667-3.5 1.25c-.76-.159-1.305-.619-1.906-1.128C13.614 5.96 12.479 5 10 5m-5 5q-4 0-5 3.334 1.5-1.668 3.5-1.25c.76.158 1.305.618 1.906 1.127C6.386 14.041 7.521 15 10 15q4 0 5-3.333-1.5 1.667-3.5 1.25c-.76-.159-1.305-.619-1.906-1.128C8.614 10.96 7.478 10 5 10" clip-rule="evenodd"></path>
      </svg>
      <span class="text-sm font-medium text-neutral-800 dark:text-neutral-200">Tailwind CSS</span>
    </div>
  <% end %>
  <% marquee.with_item do %>
    <div class="flex items-center space-x-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4 rounded-sm" viewBox="0 0 630 630">
        <rect width="630" height="630" fill="#f7df1e"/>
        <path d="m423.2 492.19c12.69 20.72 29.2 35.95 58.4 35.95 24.53 0 40.2-12.26 40.2-29.2 0-20.3-16.1-27.49-43.1-39.3l-14.8-6.35c-42.72-18.2-71.1-41-71.1-89.2 0-44.4 33.83-78.2 86.7-78.2 37.64 0 64.7 13.1 84.2 47.4l-46.1 29.6c-10.15-18.2-21.1-25.37-38.1-25.37-17.34 0-28.33 11-28.33 25.37 0 17.76 11 24.95 36.4 35.95l14.8 6.34c50.3 21.57 78.7 43.56 78.7 93 0 53.3-41.87 82.5-98.1 82.5-54.98 0-90.5-26.2-107.88-60.54zm-209.13 5.13c9.3 16.5 17.76 30.45 38.1 30.45 19.45 0 31.72-7.61 31.72-37.2v-201.3h59.2v202.1c0 61.3-35.94 89.2-88.4 89.2-47.4 0-74.85-24.53-88.81-54.075z"/>
      </svg>
      <span class="text-sm font-medium text-neutral-800 dark:text-neutral-200">JavaScript</span>
    </div>
  <% end %>
<% end %>

<!-- Fast marquee scrolling right, slows on hover -->
<%= render(Marquee::Component.new(
  speed: 10,
  hover_speed: 30,
  direction: "right",
  gap: "gap-12"
)) do |marquee| %>
  <% marquee.with_item do %>
    <span class="text-lg font-bold text-neutral-800 dark:text-neutral-200">Breaking News</span>
  <% end %>
  <% marquee.with_item do %>
    <span class="text-lg text-neutral-600 dark:text-neutral-400">Latest updates from around the world</span>
  <% end %>
  <% marquee.with_item do %>
    <span class="text-lg font-bold text-neutral-800 dark:text-neutral-200">Technology</span>
  <% end %>
  <% marquee.with_item do %>
    <span class="text-lg text-neutral-600 dark:text-neutral-400">New innovations in AI</span>
  <% end %>
<% end %>

<!-- Brand logos in cards, no gradients -->
<%= render(Marquee::Component.new(
  speed: 25,
  hover_speed: 0,
  show_fade: false,
  gap: "gap-6"
)) do |marquee| %>
  <% marquee.with_item(classes: "flex min-w-[150px] items-center justify-center rounded-xl border border-black/5 bg-neutral-50 px-6 py-4 shadow-xs dark:border-white/10 dark:bg-neutral-800") do %>
    <span class="text-lg font-medium text-neutral-800 dark:text-neutral-200">Apple</span>
  <% end %>
  <% marquee.with_item(classes: "flex min-w-[150px] items-center justify-center rounded-xl border border-black/5 bg-neutral-50 px-6 py-4 shadow-xs dark:border-white/10 dark:bg-neutral-800") do %>
    <span class="text-lg font-medium text-neutral-800 dark:text-neutral-200">Google</span>
  <% end %>
  <% marquee.with_item(classes: "flex min-w-[150px] items-center justify-center rounded-xl border border-black/5 bg-neutral-50 px-6 py-4 shadow-xs dark:border-white/10 dark:bg-neutral-800") do %>
    <span class="text-lg font-medium text-neutral-800 dark:text-neutral-200">Microsoft</span>
  <% end %>
  <% marquee.with_item(classes: "flex min-w-[150px] items-center justify-center rounded-xl border border-black/5 bg-neutral-50 px-6 py-4 shadow-xs dark:border-white/10 dark:bg-neutral-800") do %>
    <span class="text-lg font-medium text-neutral-800 dark:text-neutral-200">Amazon</span>
  <% end %>
<% end %>

<!-- Slow announcement banner, pauses completely on hover -->
<%= render(Marquee::Component.new(
  speed: 30,
  hover_speed: 0,
  pause_on_hover: true,
  classes: "bg-neutral-100 dark:bg-neutral-900 py-2"
)) do |marquee| %>
  <% marquee.with_item do %>
    <span class="text-sm text-neutral-600 dark:text-neutral-400">🎉 Free shipping on orders over $50</span>
  <% end %>
  <% marquee.with_item do %>
    <span class="text-sm text-neutral-600 dark:text-neutral-400">⭐ New arrivals just dropped</span>
  <% end %>
  <% marquee.with_item do %>
    <span class="text-sm text-neutral-600 dark:text-neutral-400">🔥 Limited time offer: 20% off</span>
  <% end %>
<% end %>

<!-- No pause on hover, continuous scroll -->
<%= render(Marquee::Component.new(
  speed: 15,
  pause_on_hover: false,
  direction: "left"
)) do |marquee| %>
  <% marquee.with_item do %>
    <span class="text-neutral-500 dark:text-neutral-400">Always scrolling</span>
  <% end %>
  <% marquee.with_item do %>
    <span class="text-neutral-500 dark:text-neutral-400">Never stops</span>
  <% end %>
  <% marquee.with_item do %>
    <span class="text-neutral-500 dark:text-neutral-400">Continuous motion</span>
  <% end %>
<% end %>
