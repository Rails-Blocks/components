<%#
  Pagination Component
  Display page navigation for paginated lists and tables using Pagy.

  Required locals:
    - pagy: Pagy - The Pagy pagination object

  Optional locals:
    - variant: String (default: "full") - Display variant: "full" (numbered), "compact" (prev/next with info), "minimal" (prev/next only)
    - size: String (default: "md") - Size variant: "sm", "md", "lg"
    - frame_id: String (default: nil) - Turbo Frame ID for SPA navigation
    - show_info: Boolean (default: true) - Show "Showing X-Y of Z" info text
    - show_page_form: Boolean (default: false) - Show "Jump to page" form (only with full variant)
    - show_limit_form: Boolean (default: false) - Show rows per page selector
    - limit_options: Array<Integer> (default: [10, 25, 50]) - Options for rows per page selector
    - preserve_params: Hash (default: {}) - Query params to preserve across page changes
    - request_path: String (default: request.path) - Custom request path for forms
    - classes: String (default: nil) - Additional CSS classes for the wrapper
%>

<% variant ||= "full" %>
<% size ||= "md" %>
<% frame_id ||= nil %>
<% show_info = true if local_assigns[:show_info].nil? %>
<% show_page_form ||= false %>
<% show_limit_form ||= false %>
<% limit_options ||= [10, 25, 50] %>
<% preserve_params ||= {} %>
<% request_path ||= request.path %>
<% classes ||= nil %>

<%
  # Normalize variant
  variant = variant.to_s
  show_page_form = show_page_form && variant == "full"
  limit_options = limit_options.map(&:to_i)

  # Keys
  page_key = pagy.options[:page_key] || "page"
  limit_key = pagy.options[:limit_key] || "limit"

  # Build query params
  query_params = preserve_params.stringify_keys.except(page_key.to_s, limit_key.to_s)
  query_params[limit_key] = pagy.limit.to_s

  # Turbo frame attribute for Pagy anchors (Pagy v43+ uses anchor_string)
  anchor_string = frame_id.present? ? "data-turbo-frame='#{frame_id}'" : nil

  # Common options for Pagy helpers
  common_opts = {
    anchor_string: anchor_string,
    querify: ->(q) { q.merge!(query_params) }
  }.compact

  # Generate nav HTML
  nav_html = pagy.series_nav(**common_opts)
  prev_html = pagy.previous_tag(**common_opts.merge(aria_label: "Previous"))
  next_html = pagy.next_tag(**common_opts.merge(aria_label: "Next"))

  # CSS classes
  wrapper_classes = ["flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between", classes].compact.reject(&:empty?).join(" ")
  nav_wrapper_classes = "inline-flex items-center gap-2 text-sm font-medium"

  info_classes = case size.to_s
    when "sm" then "text-xs text-neutral-600 dark:text-neutral-300"
    when "lg" then "text-base text-neutral-600 dark:text-neutral-300"
    else "text-sm text-neutral-600 dark:text-neutral-300"
  end
%>

<nav aria-label="Pagination" class="<%= wrapper_classes %>">
  <%# Info section %>
  <% if show_info %>
    <div class="flex items-center gap-3">
      <p class="<%= info_classes %>">
        Showing <span class="font-medium text-neutral-900 dark:text-white"><%= pagy.from %></span>–<span class="font-medium text-neutral-900 dark:text-white"><%= pagy.to %></span> of <span class="font-medium text-neutral-900 dark:text-white"><%= pagy.count %></span>
      </p>

      <% if variant == "compact" %>
        <span class="hidden sm:block border-l border-black/10 h-4 dark:border-white/10"></span>
        <p class="hidden sm:block <%= info_classes %>">
          Page <span class="font-medium text-neutral-900 dark:text-white"><%= pagy.page %></span> of <span class="font-medium text-neutral-900 dark:text-white"><%= pagy.pages %></span>
        </p>
      <% end %>
    </div>
  <% end %>

  <%# Navigation controls %>
  <div class="flex flex-wrap items-center gap-3">
    <% case variant %>
    <% when "full" %>
      <%# Full numbered pagination %>
      <div class="pagy <%= nav_wrapper_classes %>">
        <%== nav_html %>
      </div>

      <% if show_page_form %>
        <%= form_with url: request_path, method: :get, data: { turbo_frame: frame_id }, class: "flex items-center", local: true do %>
          <% query_params.except(limit_key).each do |k, v| %>
            <%= hidden_field_tag k, v %>
          <% end %>
          <%= hidden_field_tag limit_key, pagy.limit %>
          <label class="text-xs text-neutral-500 dark:text-neutral-300 mr-2">Jump to Page</label>
          <%= number_field_tag page_key, pagy.page, min: 1, max: pagy.pages, class: "w-fit rounded-l-md border border-black/10 bg-white pl-2 leading-7 text-sm dark:border-white/10 dark:bg-white/10 dark:text-white focus-visible:outline-neutral-600 dark:focus-visible:outline-neutral-200" %>
          <%= submit_tag "Go", class: "cursor-pointer rounded-r-md border border-l-0 border-black/10 bg-white px-2.5 py-1 text-sm font-medium text-neutral-800 hover:bg-neutral-50 dark:border-white/10 dark:bg-white/10 dark:text-white dark:hover:bg-white/20" %>
        <% end %>
      <% end %>

    <% when "compact", "minimal" %>
      <%# Prev/Next only %>
      <div class="pagy <%= nav_wrapper_classes %>">
        <%== prev_html %>
        <%== next_html %>
      </div>
    <% end %>

    <% if show_limit_form %>
      <%= form_with url: request_path, method: :get, data: { turbo_frame: frame_id }, class: "flex items-center gap-2", local: true do %>
        <% query_params.except(limit_key).each do |k, v| %>
          <%= hidden_field_tag k, v %>
        <% end %>
        <%= hidden_field_tag page_key, 1 %>
        <label class="text-xs text-neutral-500 dark:text-neutral-300">Rows</label>
        <%= select_tag limit_key,
          options_for_select(limit_options, pagy.limit),
          class: "rounded-md border border-black/10 bg-white px-2 py-1 text-sm text-neutral-900 shadow-xs dark:border-white/10 dark:bg-neutral-900 dark:text-white",
          onchange: "this.form.requestSubmit()" %>
      <% end %>
    <% end %>
  </div>
</nav>
