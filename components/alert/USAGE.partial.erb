<!-- Basic usage with title only -->
<%= render "shared/components/alert/alert",
  title: "Success! Your changes have been saved",
  variant: "success" %>

<!-- With description -->
<%= render "shared/components/alert/alert",
  title: "Error! Something went wrong",
  description: "There was a problem processing your request. Please try again.",
  variant: "error" %>

<!-- Warning alert -->
<%= render "shared/components/alert/alert",
  title: "Warning! Please review before proceeding",
  description: "This action requires your attention.",
  variant: "warning" %>

<!-- Info alert (blue) -->
<%= render "shared/components/alert/alert",
  title: "Information",
  description: "Here's some helpful information about this feature.",
  variant: "info" %>

<!-- Neutral alert (gray) -->
<%= render "shared/components/alert/alert",
  title: "General Notice",
  description: "This is a neutral alert for general information or updates.",
  variant: "neutral" %>

<!-- Without icon -->
<%= render "shared/components/alert/alert",
  title: "Alert without an icon",
  description: "You can hide the icon if needed.",
  show_icon: false %>

<!-- With custom classes -->
<%= render "shared/components/alert/alert",
  title: "Custom styled alert",
  description: "You can add your own classes for additional styling.",
  variant: "info",
  classes: "shadow-lg max-w-md" %>

<!-- With HTML in description -->
<%= render "shared/components/alert/alert",
  title: "HTML Description Support",
  description: "You can include <strong>bold text</strong>, <em>italics</em>, and even <a href='#' class='underline'>links</a>!",
  variant: "success" %>

<!-- With custom icon -->
<%= render "shared/components/alert/alert",
  title: "Custom Icon Alert",
  description: "This alert uses a custom rocket icon.",
  variant: "success",
  custom_icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"></path><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path></svg>' %>
