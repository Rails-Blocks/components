<div class="<%= wrapper_classes %>" <%= tag.attributes(controller_data) %>>
  <div class="bg-white dark:bg-neutral-900 rounded-xl border border-black/10 dark:border-white/10 shadow-xs overflow-hidden">
    <!-- Header with Select All -->
    <div class="px-4 py-3 border-b border-black/10 dark:border-white/10">
      <div class="flex items-center gap-x-3">
        <input
          type="checkbox"
          id="select-all-<%= unique_id %>"
          tabindex="0"
          data-checkbox-select-all-target="selectAll"
          data-action="click->checkbox-select-all#toggleAll">
        <label for="select-all-<%= unique_id %>" class="inline-block font-medium text-sm cursor-pointer select-none">
          <%= select_all_label %>
        </label>
      </div>
    </div>

    <!-- Items List -->
    <div class="divide-y divide-black/10 dark:divide-white/10">
      <% if groups.any? %>
        <% groups.each do |group| %>
          <%= group %>
        <% end %>
      <% else %>
        <% items.each do |item| %>
          <%= item %>
        <% end %>
      <% end %>
    </div>

    <% if show_action_bar %>
      <!-- Action Bar (shown when items are selected) -->
      <div class="px-4 py-3 border-t border-black/10 dark:border-white/10" data-checkbox-select-all-target="actionBar" hidden>
        <div class="flex justify-between items-center gap-4">
          <% if show_count %>
            <div class="flex gap-1 text-sm font-medium text-neutral-700 dark:text-neutral-300">
              <span data-checkbox-select-all-target="count">0</span>
              <span>selected</span>
            </div>
          <% end %>
          <div class="flex items-center gap-2">
            <%= action_bar_content %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
